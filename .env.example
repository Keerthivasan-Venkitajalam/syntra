# ──────────────────────────────────────────────────────────────────────────────
# Syntra — Environment Variables
# Copy this file to .env.local and fill in your keys.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# Linkup search API (get free credits at https://app.linkup.so)
LINKUP_API_KEY=

# ── LLM — set ONE of these ────────────────────────────────────────────────────
# Option A: Direct OpenAI
OPENAI_API_KEY=

# Option B: Vercel AI Gateway (recommended for production — adds observability)
VERCEL_AI_GATEWAY_API_KEY=
VERCEL_AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1/chat/completions

# Model (default: gpt-4o-mini). Change to openai/gpt-4.1 for best quality.
AI_MODEL=gpt-4o-mini

# ── Public URL (required for share links) ─────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# Set to "true" to enable the presentation demo layer:
#   - Stripe, Figma, acme-batteries.in return pre-built fixture reports instantly
#   - Zero real Linkup/LLM API calls for those three domains
#   - All 8 Easter egg scenarios are active
#   - Run `npm run demo:check` to verify fixtures load correctly
SYNTRA_DEMO_MODE=false
